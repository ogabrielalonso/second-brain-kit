<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd agent: the brain daemon (persistent local retrieval server, 127.0.0.1 only).
  Placeholders rendered by the installer, launchd cannot expand ~ or env vars:
    {{PYTHON}}     absolute path to the python3 interpreter to run
    {{KIT_DIR}}    absolute path to the kit checkout (default ~/.brain/kit, resolved)
    {{BRAIN_HOME}} absolute path to ~/.brain (resolved), used only for log files here

  KeepAlive + RunAtLoad: this is the one long-running service; launchd restarts it if it
  exits. Nice 10: background priority, never competes with interactive work.

  Log hygiene: StandardOutPath/StandardErrorPath below are launchd's OWN capture of
  anything the process prints to stdout/stderr. brain_daemon.py deliberately logs to
  stdout only (no internal log file of its own), so this capture is the daemon's one
  and only log; the other services (daily/weekly/aging/watchdog) do keep their own
  internal logs, separate from the launchd capture.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.brainkit.daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{PYTHON}}</string>
        <string>{{KIT_DIR}}/scripts/brain_daemon.py</string>
    </array>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>Nice</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>{{BRAIN_HOME}}/logs/daemon.launchd.log</string>
    <key>StandardErrorPath</key>
    <string>{{BRAIN_HOME}}/logs/daemon.launchd.log</string>
</dict>
</plist>
